# Copy this file to .env, then fill in your own Azure OpenAI deployment values.
# Do not commit .env.

# Azure OpenAI
AZURE_API_KEY=
AZURE_API_BASE=https://your-resource-name.openai.azure.com
AZURE_API_VERSION=2025-03-01-preview
AZURE_DEPLOYMENT_NAME=your-gpt-55-deployment-name

# LiteLLM local proxy
LITELLM_HOST=127.0.0.1
LITELLM_PORT=4000
LITELLM_MASTER_KEY=sk-local-claude-code-proxy

# Model alias exposed by LiteLLM to Claude Code.
# Keep this stable even if the Azure deployment name changes.
CLAUDE_CODE_MODEL_ALIAS=gpt-5.5

# Optional Claude Code behavior
CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1
DISABLE_TELEMETRY=1
